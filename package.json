{
  "name": "rubyn-code",
  "displayName": "Rubyn Code",
  "description": "Ruby & Rails agentic coding assistant",
  "publisher": "rubyn",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MatthewSuttles/rubyn-code-vscode"
  },
  "homepage": "https://github.com/MatthewSuttles/rubyn-code-vscode#readme",
  "bugs": {
    "url": "https://github.com/MatthewSuttles/rubyn-code-vscode/issues"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "activationEvents": [
    "onLanguage:ruby",
    "workspaceContains:Gemfile",
    "workspaceContains:.rubyn-code",
    "onStartupFinished"
  ],
  "categories": [
    "AI",
    "Programming Languages",
    "Linters"
  ],
  "icon": "resources/icon-128.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rubyn-code.openChat",
        "title": "Rubyn Code: Open Chat"
      },
      {
        "command": "rubyn-code.reviewPR",
        "title": "Rubyn Code: Review PR"
      },
      {
        "command": "rubyn-code.refactorSelection",
        "title": "Rubyn Code: Refactor Selection"
      },
      {
        "command": "rubyn-code.generateSpecs",
        "title": "Rubyn Code: Generate Specs"
      },
      {
        "command": "rubyn-code.explainCode",
        "title": "Rubyn Code: Explain Code"
      },
      {
        "command": "rubyn-code.selectModel",
        "title": "Rubyn Code: Select Model"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rubyn-code",
          "title": "Rubyn Code",
          "icon": "resources/icon.png"
        }
      ]
    },
    "viewsDefaultLocation": {
      "rubyn-code.chat": "secondary",
      "rubyn-code.sessions": "secondary"
    },
    "views": {
      "rubyn-code": [
        {
          "id": "rubyn-code.chat",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "rubyn-code.sessions",
          "name": "Sessions"
        }
      ]
    },
    "configuration": {
      "title": "Rubyn Code",
      "properties": {
        "rubyn-code.executablePath": {
          "type": "string",
          "default": "rubyn-code",
          "description": "Path to the rubyn-code CLI executable.",
          "order": 0
        },
        "rubyn-code.provider": {
          "type": "string",
          "default": "anthropic",
          "enum": ["anthropic", "openai"],
          "enumDescriptions": [
            "Anthropic (Claude models)",
            "OpenAI (GPT models)"
          ],
          "description": "Active LLM provider.",
          "order": 1
        },
        "rubyn-code.model": {
          "type": "string",
          "default": "claude-opus-4-6",
          "description": "Model to use for completions. Available models depend on the selected provider.",
          "order": 2
        },
        "rubyn-code.sessionBudget": {
          "type": "number",
          "default": 5.0,
          "minimum": 0.1,
          "maximum": 100,
          "description": "Maximum spending per session (USD).",
          "order": 3
        },
        "rubyn-code.dailyBudget": {
          "type": "number",
          "default": 10.0,
          "minimum": 0.5,
          "maximum": 500,
          "description": "Maximum daily spending across all sessions (USD).",
          "order": 4
        },
        "rubyn-code.maxIterations": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "maximum": 1000,
          "description": "Maximum agent loop iterations per prompt.",
          "order": 5
        },
        "rubyn-code.contextThreshold": {
          "type": "number",
          "default": 80000,
          "minimum": 10000,
          "maximum": 200000,
          "description": "Token count that triggers context compaction.",
          "order": 6
        },
        "rubyn-code.yoloMode": {
          "type": "boolean",
          "default": false,
          "description": "Auto-approve all tool calls without confirmation.",
          "order": 7
        }
      }
    },
    "keybindings": [
      {
        "command": "rubyn-code.openChat",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "rubyn-code.refactorSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "package": "vsce package",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.98.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.2.0",
    "css-loader": "^7.1.0",
    "eslint": "^9.0.0",
    "mini-css-extract-plugin": "^2.10.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0"
  },
  "dependencies": {
    "lit": "^3.3.2"
  }
}
