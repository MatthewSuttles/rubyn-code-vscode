{
  "name": "rubyn-code",
  "displayName": "Rubyn Code",
  "description": "Ruby & Rails agentic coding assistant",
  "publisher": "rubyn",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MatthewSuttles/rubyn-code-vscode"
  },
  "homepage": "https://github.com/MatthewSuttles/rubyn-code-vscode#readme",
  "bugs": {
    "url": "https://github.com/MatthewSuttles/rubyn-code-vscode/issues"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "activationEvents": [
    "onLanguage:ruby",
    "workspaceContains:Gemfile",
    "workspaceContains:.rubyn-code",
    "onStartupFinished"
  ],
  "categories": [
    "AI",
    "Programming Languages",
    "Linters"
  ],
  "icon": "resources/icon-128.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rubyn-code.openChat",
        "title": "Rubyn Code: Open Chat"
      },
      {
        "command": "rubyn-code.reviewPR",
        "title": "Rubyn Code: Review PR"
      },
      {
        "command": "rubyn-code.refactorSelection",
        "title": "Rubyn Code: Refactor Selection"
      },
      {
        "command": "rubyn-code.generateSpecs",
        "title": "Rubyn Code: Generate Specs"
      },
      {
        "command": "rubyn-code.explainCode",
        "title": "Rubyn Code: Explain Code"
      },
      {
        "command": "rubyn-code.selectModel",
        "title": "Rubyn Code: Select Model"
      },
      {
        "command": "rubyn-code.acceptEdit",
        "title": "Accept Rubyn Edit",
        "icon": "$(check)"
      },
      {
        "command": "rubyn-code.rejectEdit",
        "title": "Reject Rubyn Edit",
        "icon": "$(close)"
      },
      {
        "command": "rubyn-code.refactorFromDiagnostic",
        "title": "Rubyn Code: Refactor from Diagnostic"
      },
      {
        "command": "rubyn-code.refactorSelection.background",
        "title": "Rubyn Code: Refactor Selection (Background)"
      },
      {
        "command": "rubyn-code.generateSpecs.background",
        "title": "Rubyn Code: Generate Specs (Background)"
      },
      {
        "command": "rubyn-code.explainCode.background",
        "title": "Rubyn Code: Explain Code (Background)"
      },
      {
        "command": "rubyn-code.viewTaskResult",
        "title": "Rubyn Code: View Task Result"
      },
      {
        "command": "rubyn-code.cancelTask",
        "title": "Cancel",
        "icon": "$(stop-circle)"
      },
      {
        "command": "rubyn-code.dismissTask",
        "title": "Dismiss",
        "icon": "$(close)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "rubyn-code.acceptEdit",
          "when": "resourceScheme == rubyn-proposed",
          "group": "navigation@1"
        },
        {
          "command": "rubyn-code.rejectEdit",
          "when": "resourceScheme == rubyn-proposed",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "rubyn-code.acceptEdit",
          "when": "false"
        },
        {
          "command": "rubyn-code.rejectEdit",
          "when": "false"
        },
        {
          "command": "rubyn-code.refactorFromDiagnostic",
          "when": "false"
        },
        {
          "command": "rubyn-code.viewTaskResult",
          "when": "false"
        },
        {
          "command": "rubyn-code.cancelTask",
          "when": "false"
        },
        {
          "command": "rubyn-code.dismissTask",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "rubyn-code.cancelTask",
          "when": "view == rubyn-code.sessions && viewItem == task.running",
          "group": "inline@1"
        },
        {
          "command": "rubyn-code.dismissTask",
          "when": "view == rubyn-code.sessions && viewItem == task.terminal",
          "group": "inline@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rubyn-code",
          "title": "Rubyn Code",
          "icon": "resources/icon.png"
        }
      ]
    },
    "viewsDefaultLocation": {
      "rubyn-code.chat": "secondary",
      "rubyn-code.sessions": "secondary"
    },
    "views": {
      "rubyn-code": [
        {
          "id": "rubyn-code.chat",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "rubyn-code.sessions",
          "name": "Sessions"
        }
      ]
    },
    "configuration": {
      "title": "Rubyn Code",
      "properties": {
        "rubyn-code.executablePath": {
          "type": "string",
          "default": "rubyn-code",
          "description": "Path to the rubyn-code CLI executable.",
          "order": 0
        },
        "rubyn-code.provider": {
          "type": "string",
          "default": "anthropic",
          "enum": [
            "anthropic",
            "openai"
          ],
          "enumDescriptions": [
            "Anthropic (Claude models)",
            "OpenAI (GPT models)"
          ],
          "description": "Active LLM provider.",
          "order": 1
        },
        "rubyn-code.model": {
          "type": "string",
          "default": "claude-opus-4-6",
          "description": "Model to use for completions. Available models depend on the selected provider.",
          "order": 2
        },
        "rubyn-code.sessionBudget": {
          "type": "number",
          "default": 5,
          "minimum": 0.1,
          "maximum": 100,
          "description": "Maximum spending per session (USD).",
          "order": 3
        },
        "rubyn-code.dailyBudget": {
          "type": "number",
          "default": 10,
          "minimum": 0.5,
          "maximum": 500,
          "description": "Maximum daily spending across all sessions (USD).",
          "order": 4
        },
        "rubyn-code.maxIterations": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "maximum": 1000,
          "description": "Maximum agent loop iterations per prompt.",
          "order": 5
        },
        "rubyn-code.contextThreshold": {
          "type": "number",
          "default": 80000,
          "minimum": 10000,
          "maximum": 200000,
          "description": "Token count that triggers context compaction.",
          "order": 6
        },
        "rubyn-code.permissionMode": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "accept_edits",
            "plan_only",
            "auto",
            "dont_ask",
            "bypass"
          ],
          "enumDescriptions": [
            "Approve every mutating tool and file edit",
            "Auto-approve file edits, prompt for other mutations",
            "Read-only mode — block all writes",
            "Auto-approve everything except deny-listed",
            "Auto-deny all mutations unless pre-approved",
            "No checks — auto-approve everything"
          ],
          "description": "Permission mode for tool execution.",
          "order": 7
        },
        "rubyn-code.completion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable schema-aware column completion inside ActiveRecord query methods (where, order, find_by, …).",
          "order": 8
        },
        "rubyn-code.completion.routes": {
          "type": "boolean",
          "default": true,
          "description": "Enable Rails route-helper completion (*_path, *_url) in views, controllers, and mailers.",
          "order": 9
        },
        "rubyn-code.completion.associations": {
          "type": "boolean",
          "default": true,
          "description": "Enable association, scope, and ActiveRecord-method completion on model traversal chains.",
          "order": 10
        },
        "rubyn-code.completion.associations.debug": {
          "type": "boolean",
          "default": false,
          "description": "Log ReceiverTypeResolver decisions to the Rubyn Code output channel (for debugging completion behavior).",
          "order": 11
        },
        "rubyn-code.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Master switch for Rubyn Code class-complexity diagnostics (method count, LCOM4, fan-out, cyclomatic complexity).",
          "order": 12
        },
        "rubyn-code.diagnostics.methodCountThreshold": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "description": "Warn when a class has more than this many public methods. Set to 0 to disable the signal.",
          "order": 13
        },
        "rubyn-code.diagnostics.lcomMinMethods": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "description": "Minimum method count for LCOM4 to evaluate the class. Set to 0 to disable.",
          "order": 14
        },
        "rubyn-code.diagnostics.fanOutThreshold": {
          "type": "number",
          "default": 10,
          "minimum": 0,
          "description": "Info when a class references more than this many distinct external classes. Set to 0 to disable.",
          "order": 15
        },
        "rubyn-code.diagnostics.cyclomaticThreshold": {
          "type": "number",
          "default": 8,
          "minimum": 0,
          "description": "Warn when a single method's cyclomatic complexity exceeds this. Set to 0 to disable.",
          "order": 16
        },
        "rubyn-code.tasks.notifications": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code notification when a background task completes or fails.",
          "order": 17
        }
      }
    },
    "keybindings": [
      {
        "command": "rubyn-code.openChat",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "rubyn-code.refactorSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "rubyn-code.refactorSelection.background",
        "key": "ctrl+alt+shift+e",
        "mac": "cmd+alt+shift+e",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "package": "vsce package",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.98.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.2.0",
    "ajv": "^8.0.0",
    "ajv-formats": "^3.0.0",
    "css-loader": "^7.1.0",
    "eslint": "^9.0.0",
    "mini-css-extract-plugin": "^2.10.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0"
  },
  "dependencies": {
    "lit": "^3.3.2"
  }
}
